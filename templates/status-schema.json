{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Status",
  "description": "Per-agent status file for NM i AI 2026 competition",
  "type": "object",
  "required": ["agent", "timestamp", "track", "phase", "state", "confidence"],
  "properties": {
    "agent": {
      "type": "string",
      "enum": ["agent-cv", "agent-ml", "agent-nlp"],
      "description": "Agent identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Last update time (ISO 8601 with timezone)"
    },
    "track": {
      "type": "string",
      "enum": ["computer-vision", "machine-learning", "nlp"],
      "description": "Competition track"
    },
    "phase": {
      "type": "string",
      "enum": ["recon", "research", "plan", "build", "polish", "done"],
      "description": "Current competition phase"
    },
    "state": {
      "type": "string",
      "enum": ["waiting", "recon", "researching", "planning", "coding", "testing", "optimizing", "done"],
      "description": "Current work state within phase"
    },
    "approach": {
      "type": "string",
      "description": "Current approach: A (primary), B (fallback), C (baseline)"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Agent confidence in current approach (0-1)"
    },
    "local_score": {
      "type": "number",
      "description": "Best local validation score"
    },
    "best_submitted_score": {
      "type": "number",
      "description": "Best score from actual competition submission"
    },
    "submissions_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Total submissions made"
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Current blockers (empty if none)"
    },
    "hours_since_improvement": {
      "type": "number",
      "minimum": 0,
      "description": "Hours since last score improvement"
    },
    "rules_last_read": {
      "type": "string",
      "format": "date-time",
      "description": "When rules.md was last read (ISO 8601)"
    }
  }
}
